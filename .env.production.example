# ───── KROYS Inventory Next.js · variables de producción ─────
# Copia este archivo a .env.production y completa los valores.

# Conexión a las DBs existentes (mismas que usa el legacy).
# Como el contenedor está en la misma red docker que inventory_db_ve / inventory_db_co,
# usa el nombre del contenedor como host (NO localhost, NO la IP del VPS).
DATABASE_URL_VE=postgresql://postgres:TU_PASSWORD_DB@inventory_db_ve:5432/inventory_ve
DATABASE_URL_CO=postgresql://postgres:TU_PASSWORD_DB@inventory_db_co:5432/inventory_co

# NextAuth — genera un secret nuevo en el VPS con:
#   openssl rand -base64 32
NEXTAUTH_SECRET=PEGA_AQUI_EL_SECRET_GENERADO
# URL pública del sistema. DEBE ser el dominio real con https, o el logout y
# los redirects de NextAuth irán al sitio equivocado.
NEXTAUTH_URL=https://inventory.syncsora.com

NEXT_PUBLIC_APP_NAME=Syncsora Inventory

# Solo VE — fuente de tasas BCV
DOLAR_API_URL=https://ve.dolarapi.com/v1/dolares

# Uploads de importaciones. El legacy las guarda en /app/uploads/ DENTRO del
# contenedor inventory_backend. docker-compose.prod.yml monta el host ./uploads
# en /app/uploads para compartirlas. Paso único en el VPS (antes de levantar):
#   mkdir -p ./uploads && docker cp inventory_backend:/app/uploads/. ./uploads/
# Así el nuevo sistema lee las fotos existentes y las nuevas quedan en el host.
UPLOAD_DIR=/app/uploads
